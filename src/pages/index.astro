---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    // Sort by sortOrder first (lower = higher), then by pubDate
    const orderA = a.data.sortOrder ?? 999;
    const orderB = b.data.sortOrder ?? 999;
    if (orderA !== orderB) return orderA - orderB;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 6);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero Section -->
      <section class="hero">
        <h1>Sorcery Brasil</h1>
        <p class="hero-subtitle">O portal brasileiro de Sorcery: Contested Realm</p>
        <p class="hero-description">
          Guias completos, regras explicadas, dicas de deckbuilding e tudo sobre o TCG que está conquistando jogadores ao redor do mundo.
        </p>
        <div class="hero-cta">
          <a href="/comecar" class="btn btn-primary">Começar a Jogar</a>
          <a href={SOCIAL_LINKS.discord} class="btn btn-secondary" target="_blank" rel="noopener">
            Entrar no Discord
          </a>
        </div>
      </section>

      <!-- Quick Links -->
      <section class="quick-links">
        <a href="/comecar" class="quick-link">
          <span class="icon">🎓</span>
          <span class="label">Começar</span>
        </a>
        <a href="/decks" class="quick-link">
          <span class="icon">🃏</span>
          <span class="label">Decks</span>
        </a>
        <a href="/regras" class="quick-link">
          <span class="icon">📜</span>
          <span class="label">Regras</span>
        </a>
        <a href="/glossario" class="quick-link">
          <span class="icon">📖</span>
          <span class="label">Glossário</span>
        </a>
        <a href="/sets" class="quick-link">
          <span class="icon">✨</span>
          <span class="label">Sets</span>
        </a>
      </section>

      <!-- Artigos Section -->
      <section class="articles-section">
        <div class="section-header">
          <h2>Artigos</h2>
          <a href="/blog" class="view-all">Ver Todos →</a>
        </div>
        <div class="posts-grid">
          {posts.map((post, index) => (
            <PostCard post={post} featured={index === 0} />
          ))}
        </div>
      </section>

      <!-- Community Section -->
      <section class="community-section">
        <h2>Junte-se à Comunidade</h2>
        <p>Conecte-se com outros jogadores brasileiros, tire dúvidas e fique por dentro das novidades.</p>
        <div class="community-links">
          <a href={SOCIAL_LINKS.discord} class="community-card" target="_blank" rel="noopener">
            <span class="icon">💬</span>
            <span class="name">Discord</span>
            <span class="description">Chat ao vivo com a comunidade</span>
          </a>
          <a href={SOCIAL_LINKS.reddit} class="community-card" target="_blank" rel="noopener">
            <span class="icon">🌐</span>
            <span class="name">Reddit</span>
            <span class="description">r/SorceryTCG internacional</span>
          </a>
          <a href={SOCIAL_LINKS.curiosa} class="community-card" target="_blank" rel="noopener">
            <span class="icon">🔍</span>
            <span class="name">Curiosa.io</span>
            <span class="description">Database oficial de cartas</span>
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-4);
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-12) var(--space-4);
    background: linear-gradient(180deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: var(--space-2);
  }

  .hero-subtitle {
    font-family: var(--font-cinzel), serif;
    color: var(--color-gold-light);
    font-size: 1.25rem;
    margin-bottom: var(--space-4);
  }

  .hero-description {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto var(--space-6);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-gold);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-gold-light);
  }

  .btn-secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Quick Links */
  .quick-links {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }

  .quick-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 100px;
  }

  .quick-link:hover {
    border-color: var(--color-gold);
    transform: translateY(-2px);
  }

  .quick-link .icon {
    font-size: 2rem;
  }

  .quick-link .label {
    color: var(--color-text);
    font-weight: 600;
  }

  .quick-link:hover .label {
    color: var(--color-gold);
  }

  /* Articles Section */
  .articles-section {
    margin-bottom: var(--space-12);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .section-header h2 {
    margin: 0;
  }

  .view-all {
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 600;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* Community */
  .community-section {
    text-align: center;
    padding: var(--space-8);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .community-section h2 {
    margin-bottom: var(--space-2);
  }

  .community-section > p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .community-links {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .community-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-6);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .community-card:hover {
    border-color: var(--color-gold);
    transform: translateY(-2px);
  }

  .community-card .icon {
    font-size: 2rem;
  }

  .community-card .name {
    font-weight: 600;
    color: var(--color-text);
  }

  .community-card:hover .name {
    color: var(--color-gold);
  }

  .community-card .description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .quick-links {
      gap: var(--space-2);
    }

    .quick-link {
      min-width: 80px;
      padding: var(--space-3);
    }

    .quick-link .icon {
      font-size: 1.5rem;
    }

    .community-links {
      flex-direction: column;
    }
  }
</style>
