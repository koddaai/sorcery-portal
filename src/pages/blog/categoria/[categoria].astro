---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import { CATEGORIES, SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = Object.keys(CATEGORIES);

  return categories.map((categoria) => ({
    params: { categoria },
    props: {
      posts: posts
        .filter((post) => post.data.category === categoria && !post.data.draft)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { categoria } = Astro.params;
const { posts } = Astro.props;
const categoryInfo = CATEGORIES[categoria as keyof typeof CATEGORIES];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={`${categoryInfo?.name || categoria} | ${SITE_TITLE}`}
      description={categoryInfo?.description || `Artigos sobre ${categoria} em Sorcery: Contested Realm`}
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="category-header">
        <span class="category-icon">{categoryInfo?.icon || '📄'}</span>
        <h1>{categoryInfo?.name || categoria}</h1>
        <p>{categoryInfo?.description || `Artigos sobre ${categoria}`}</p>
      </section>

      <nav class="category-nav">
        <a href="/blog" class="category-pill">Todos</a>
        {Object.entries(CATEGORIES).map(([slug, cat]) => (
          <a
            href={`/blog/categoria/${slug}`}
            class:list={['category-pill', { active: slug === categoria }]}
          >
            <span class="icon">{cat.icon}</span>
            {cat.name}
          </a>
        ))}
      </nav>

      {posts.length > 0 ? (
        <section class="posts-grid">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </section>
      ) : (
        <div class="empty-state">
          <p>Ainda não há artigos nesta categoria.</p>
          <a href="/blog">Ver todos os artigos</a>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  .category-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .category-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--space-3);
  }

  .category-header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }

  .category-header p {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .category-pill:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .category-pill.active {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-bg);
  }

  .category-pill .icon {
    font-size: 1rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .empty-state a {
    color: var(--color-gold);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .category-header h1 {
      font-size: 2rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .category-nav {
      gap: var(--space-1);
    }

    .category-pill {
      font-size: 0.75rem;
      padding: var(--space-1) var(--space-2);
    }
  }
</style>
