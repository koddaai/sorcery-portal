---
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';

const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="footer-brand">
      <span class="logo">{SITE_TITLE}</span>
      <p>O portal brasileiro de Sorcery: Contested Realm</p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Conteúdo</h4>
        <a href="/comecar">Começar</a>
        <a href="/decks">Decks</a>
        <a href="/regras">Regras</a>
        <a href="/glossario">Glossário</a>
      </div>

      <div class="link-group">
        <h4>Comunidade</h4>
        <a href={SOCIAL_LINKS.discord} target="_blank" rel="noopener">Discord</a>
        <a href={SOCIAL_LINKS.reddit} target="_blank" rel="noopener">Reddit</a>
        <a href={SOCIAL_LINKS.curiosa} target="_blank" rel="noopener">Curiosa.io</a>
      </div>

      <div class="link-group">
        <h4>Recursos</h4>
        <a href={SOCIAL_LINKS.tcgplayer} target="_blank" rel="noopener">TCGPlayer</a>
        <a href="/blog">Artigos</a>
        <a href="/sets">Sets</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {today.getFullYear()} {SITE_TITLE}. Conteúdo feito com carinho pela comunidade brasileira.</p>
    <p class="disclaimer">
      Sorcery: Contested Realm é marca registrada de Erik's Curiosa LLC. Este site não é afiliado oficialmente.
    </p>
  </div>
</footer>

<style>
  footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    padding: var(--space-8) var(--space-4);
    margin-top: var(--space-12);
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .footer-brand {
    max-width: 300px;
  }

  .logo {
    font-family: var(--font-cinzel), serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .footer-brand p {
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
    font-size: 0.875rem;
  }

  .footer-links {
    display: flex;
    gap: var(--space-8);
  }

  .link-group h4 {
    font-family: var(--font-cinzel), serif;
    font-size: 0.875rem;
    color: var(--color-gold);
    margin-bottom: var(--space-3);
  }

  .link-group a {
    display: block;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    padding: var(--space-1) 0;
    transition: color 0.2s ease;
  }

  .link-group a:hover {
    color: var(--color-gold);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: var(--space-6) auto 0;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .disclaimer {
    font-size: 0.75rem !important;
    margin-top: var(--space-2) !important;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-brand {
      max-width: none;
    }

    .footer-links {
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
