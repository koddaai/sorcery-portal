---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../consts';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const category = CATEGORIES[post.data.category as keyof typeof CATEGORIES];
---

<article class:list={['post-card', { featured }]}>
  <a href={`/blog/${post.id}/`}>
    {post.data.heroImage ? (
      <Image
        class="post-image"
        width={featured ? 800 : 400}
        height={featured ? 400 : 200}
        src={post.data.heroImage}
        alt={post.data.title}
      />
    ) : (
      <div class="post-image placeholder">
        <span class="category-icon">{category?.icon || '📄'}</span>
      </div>
    )}
    <div class="post-content">
      <span class="category-badge">{category?.name || post.data.category}</span>
      <h3 class="post-title">{post.data.title}</h3>
      <p class="post-description">{post.data.description}</p>
      <time class="post-date">
        <FormattedDate date={post.data.pubDate} />
      </time>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .post-card a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: var(--color-bg-tertiary);
  }

  .post-image.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-tertiary) 0%, var(--color-bg-secondary) 100%);
  }

  .category-icon {
    font-size: 3rem;
    opacity: 0.5;
  }

  .post-content {
    padding: var(--space-4);
  }

  .category-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background: rgba(212, 175, 55, 0.15);
    color: var(--color-gold);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .post-title {
    font-family: var(--font-cinzel), serif;
    font-size: 1.125rem;
    color: var(--color-text);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card:hover .post-title {
    color: var(--color-gold);
  }

  .post-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Featured card style */
  .post-card.featured {
    grid-column: span 2;
  }

  .post-card.featured .post-image {
    height: 280px;
  }

  .post-card.featured .post-title {
    font-size: 1.5rem;
  }

  .post-card.featured .post-description {
    -webkit-line-clamp: 3;
  }

  @media (max-width: 768px) {
    .post-card.featured {
      grid-column: span 1;
    }

    .post-card.featured .post-image {
      height: 200px;
    }

    .post-card.featured .post-title {
      font-size: 1.25rem;
    }
  }
</style>
